{
  "$schema": "https://github.com/MountainUnicorn/add/config.schema.json",
  "version": "0.5.0",
  "project": {
    "name": "drugs",
    "description": "Go microservice API cache/proxy — queries configurable REST APIs and stores responses in MongoDB",
    "created": "2026-03-05",
    "author": "calebdunn"
  },
  "maturity": {
    "level": "beta",
    "promoted_from": "alpha",
    "promoted_date": "2026-03-07",
    "next_promotion_criteria": "30+ days production stability, SLAs defined, defect rate below threshold, full CI/CD pipeline"
  },
  "architecture": {
    "languages": [
      {
        "name": "Go",
        "version": "1.22+",
        "role": "backend"
      }
    ],
    "backend": {
      "framework": "net/http",
      "version": "stdlib",
      "runtime": "Go 1.22+"
    },
    "frontend": {
      "framework": null,
      "version": null,
      "bundler": "none"
    },
    "database": {
      "type": "MongoDB",
      "version": "latest"
    },
    "containerized": true,
    "container_strategy": "docker-compose",
    "suggested_by_claude": false
  },
  "infrastructure": {
    "git_host": "github",
    "git_remote": null,
    "cloud_provider": "self-hosted",
    "cloud_services": [],
    "cicd": {
      "platform": "github-actions",
      "scaffolded_by_add": true,
      "pipeline_file": ".github/workflows/ci.yml"
    },
    "infrastructure_as_code": "none"
  },
  "environments": {
    "tier": 3,
    "local": {
      "run": "docker-compose up",
      "test": "go test ./...",
      "e2e": "go test ./tests/e2e/...",
      "url": "http://localhost:8080"
    },
    "dev": {
      "deploy_trigger": null,
      "url": null,
      "verify": ["unit_tests"]
    },
    "staging": {
      "deploy_trigger": "push to main (beta tag)",
      "url": "http://192.168.1.145:8083",
      "image_tag": "beta",
      "compose_file": "docker-compose.staging.yml",
      "verify": ["unit_tests", "integration_tests", "smoke_tests"],
      "autoPromote": false
    },
    "production": {
      "deploy_trigger": "push git tag v*",
      "verify": ["smoke_tests"],
      "url": "http://192.168.1.86:8083",
      "image_tag": "latest",
      "compose_file": "docker-compose.prod.yml",
      "requires_approval": true,
      "autoPromote": false
    }
  },
  "quality": {
    "mode": "standard",
    "coverage_threshold": 80,
    "type_check_blocking": true,
    "e2e_required": false,
    "screenshot_protocol": false,
    "lint": {
      "backend": "golangci-lint run ./...",
      "frontend": null
    },
    "typecheck": {
      "backend": "go vet ./...",
      "frontend": null
    },
    "test": {
      "unit": "go test ./... -short",
      "integration": "go test ./... -run Integration",
      "e2e": "go test ./tests/e2e/..."
    }
  },
  "collaboration": {
    "autonomy_level": "autonomous",
    "team_size": "small-team",
    "commit_review_gate": false,
    "pr_review_gate": true,
    "deploy_approval_required": true
  },
  "source_control": {
    "branching": "feature-branches",
    "default_branch": "main",
    "commit_convention": "conventional",
    "pr_template": true,
    "protected_branches": ["main"]
  },
  "branding": {
    "accentColor": "#0891b2",
    "presetName": "ocean",
    "palette": {
      "accent": "#0891b2",
      "accentLight": "#22d3ee",
      "accentDark": "#0e7490",
      "accentMuted": "#67e8f9",
      "accentGlow": "rgba(8,145,178,0.4)",
      "gradientStart": "#0891b2",
      "gradientMid": "#0ea5e9",
      "gradientEnd": "#6366f1",
      "success": "#22c55e",
      "warning": "#eab308",
      "info": "#0ea5e9"
    },
    "fonts": null,
    "tone": null,
    "logoPath": null,
    "styleGuideSource": null
  },
  "imageGeneration": {
    "enabled": false,
    "tool": null,
    "plugin": null,
    "nudged": false,
    "lastDetected": null
  },
  "changelog": {
    "lastProcessedCommit": "f06cadacdeb2d002a2897efe218c5b989bd94787",
    "lastVersionTag": "v0.9.0"
  },
  "planning": {
    "current_milestone": "M17",
    "current_cycle": "cycle-12",
    "wip_limit": 3,
    "parallel_agents": 1,
    "cycle_history": []
  }
}
