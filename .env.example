# MongoDB connection string (required)
# Priority: MONGO_URI env var > database.uri in config.yaml
MONGO_URI=mongodb://localhost:27017/drugs

# Path to YAML config file (default: config.yaml)
CONFIG_PATH=config.yaml

# Server listen address (default: :8080)
LISTEN_ADDR=:8080

# rx-dag NDC Loader API key (required for fda-ndc and rx-dag-* slugs)
# Used via ${RXDAG_API_KEY} in config.yaml headers
RXDAG_API_KEY=
