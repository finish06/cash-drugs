{
    "swagger": "2.0",
    "info": {
        "description": "API cache/proxy — fetches from upstream REST APIs, stores in MongoDB, serves cached data to internal consumers.",
        "title": "drugs API",
        "contact": {},
        "version": "0.2.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/cache/{slug}": {
            "get": {
                "description": "Returns cached upstream API data. Fetches from upstream if not cached.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "cache"
                ],
                "summary": "Get cached data for an endpoint",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Endpoint slug from config",
                        "name": "slug",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "SPL set ID (for spl-detail, spl-xml)",
                        "name": "SETID",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Drug name (for spls-by-name)",
                        "name": "DRUGNAME",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Drug class (for spls-by-class)",
                        "name": "DRUG_CLASS",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Brand name (for fda-ndc-by-name, fda-drugsfda-by-name)",
                        "name": "BRAND_NAME",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Drug name (for fda-labels-by-name, fda-events-by-drug)",
                        "name": "DRUG_NAME",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Force upstream refresh (true/false)",
                        "name": "_force",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_finish06_drugs_internal_model.APIResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/github_com_finish06_drugs_internal_model.ErrorResponse"
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "$ref": "#/definitions/github_com_finish06_drugs_internal_model.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/endpoints": {
            "get": {
                "description": "Returns all configured upstream API endpoints with their metadata.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "List configured endpoints",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/internal_handler.EndpointInfo"
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Returns service health status including database connectivity.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "Degraded",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/openapi.json": {
            "get": {
                "description": "Returns the OpenAPI 3.0 JSON specification for this API.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "OpenAPI specification",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_finish06_drugs_internal_model.APIResponse": {
            "type": "object",
            "properties": {
                "data": {},
                "meta": {
                    "$ref": "#/definitions/github_com_finish06_drugs_internal_model.ResponseMeta"
                }
            }
        },
        "github_com_finish06_drugs_internal_model.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "slug": {
                    "type": "string"
                },
                "upstream_status": {
                    "type": "integer"
                }
            }
        },
        "github_com_finish06_drugs_internal_model.ResponseMeta": {
            "type": "object",
            "properties": {
                "fetched_at": {
                    "type": "string"
                },
                "page_count": {
                    "type": "integer"
                },
                "slug": {
                    "type": "string"
                },
                "source_url": {
                    "type": "string"
                },
                "stale": {
                    "type": "boolean"
                },
                "stale_reason": {
                    "type": "string"
                }
            }
        },
        "internal_handler.EndpointInfo": {
            "type": "object",
            "properties": {
                "format": {
                    "type": "string"
                },
                "pagination": {
                    "type": "boolean"
                },
                "params": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "path": {
                    "type": "string"
                },
                "scheduled": {
                    "type": "boolean"
                },
                "slug": {
                    "type": "string"
                }
            }
        }
    }
}