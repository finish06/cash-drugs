{
    "swagger": "2.0",
    "info": {
        "description": "API cache/proxy — fetches from upstream REST APIs, stores in MongoDB, serves cached data to internal consumers.",
        "title": "cash-drugs API",
        "contact": {},
        "version": "0.10.1"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/cache/status": {
            "get": {
                "description": "Returns per-slug cache health including staleness, TTL remaining, and health score.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Cache status overview",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_handler.CacheStatusResponse"
                        }
                    }
                }
            }
        },
        "/api/cache/{slug}": {
            "get": {
                "description": "Returns cached upstream API data. Fetches from upstream if not cached.\nThe response data shape depends on the upstream API. For example, the\n`drugclasses` endpoint returns objects with fields: `name` (string),\n`type` (string), `code` (string), `codingSystem` (string).\nAvailable query parameters vary by endpoint — use `GET /api/endpoints`\nto discover each endpoint's supported params (e.g. BRAND_NAME, GENERIC_NAME,\nNDC, PHARM_CLASS for fda-ndc; SETID for spl-detail).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "cache"
                ],
                "summary": "Get cached data for an endpoint",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Endpoint slug from config",
                        "name": "slug",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Path parameter value (varies by endpoint)",
                        "name": "SETID",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Force upstream refresh (true/false)",
                        "name": "_force",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_finish06_cash-drugs_internal_model.APIResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/github_com_finish06_cash-drugs_internal_model.ErrorResponse"
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "$ref": "#/definitions/github_com_finish06_cash-drugs_internal_model.ErrorResponse"
                        }
                    },
                    "503": {
                        "description": "Service overloaded or upstream circuit open",
                        "schema": {
                            "$ref": "#/definitions/github_com_finish06_cash-drugs_internal_model.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/endpoints": {
            "get": {
                "description": "Returns all configured upstream API endpoints with their metadata.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "List configured endpoints",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/internal_handler.EndpointInfo"
                            }
                        }
                    }
                }
            }
        },
        "/api/warmup": {
            "post": {
                "description": "Triggers background warm-up of cached endpoints. With no body, warms all scheduled endpoints. With {\"slugs\": [...]}, warms specific slugs.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Trigger cache warmup",
                "parameters": [
                    {
                        "description": "Optional slug filter",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "type": "object"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Warmup started",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Invalid slug",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "405": {
                        "description": "Method not allowed",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Returns service health status including database connectivity.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "Degraded",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/openapi.json": {
            "get": {
                "description": "Returns the OpenAPI 3.0 JSON specification for this API.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "OpenAPI specification",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object"
                        }
                    }
                }
            }
        },
        "/ready": {
            "get": {
                "description": "Returns whether the service has finished warming its cache.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Readiness probe",
                "responses": {
                    "200": {
                        "description": "Ready",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "Warming",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/version": {
            "get": {
                "description": "Returns build metadata, runtime info, and uptime for deployment verification.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Version and build info",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_handler.VersionInfo"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
